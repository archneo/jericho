[Unit]
Description=Jericho Shell Microservice
After=network.target

[Service]
Type=simple
User=${JERICHO_USER}
WorkingDirectory=${INSTALL_DIR}/shell
Environment="JERICHO_SECRET_KEY=${JERICHO_SECRET_KEY}"
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 ${INSTALL_DIR}/shell/main.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
